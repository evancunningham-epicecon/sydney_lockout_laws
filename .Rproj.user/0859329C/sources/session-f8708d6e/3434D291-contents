# ── Helper: read ABS Sheet1 key file ─────────────────────────────────────────
read_abs_key <- function(path) {
  read_excel(path, sheet = "Sheet1", col_names = FALSE) %>%
    slice(-1) %>%                                      # drop blank row 2
    rename(
      description = `...1`,
      series_type  = `...4`,
      series_id    = `...5`,
      freq         = `...11`
    ) %>%
    filter(!is.na(series_id)) %>%
    select(description, series_type, series_id, freq)
}

# ── Helper: read ABS DataX sheets ────────────────────────────────────────────
read_abs_data <- function(file_path) {
  xl          <- excel_sheets(file_path)
  data_sheets <- xl[str_detect(xl, "^Data\\d+$")]
  
  map_dfr(data_sheets, function(sh) {
    raw <- read_excel(file_path, sheet = sh, col_names = FALSE)
    
    # Row 10 (1-indexed): Series IDs across columns 2+
    series_ids <- raw[10, -1] %>% unlist() %>% unname()
    
    # Rows 11+: col 1 = dates, cols 2+ = values
    # Slice data rows first so col 1 is a clean datetime vector (no mixed types)
    data_rows <- raw[11:nrow(raw), ]
    
    # Pull dates as numeric (Excel serial) and convert via janitor-safe method
    dates <- data_rows[[1]] %>% as.numeric() %>% as.Date(origin = "1899-12-30")
    
    data_rows[-1] %>%
      set_names(series_ids) %>%
      mutate(Period = dates) %>%
      pivot_longer(-Period, names_to = "Series_ID", values_to = "Value") %>%
      mutate(Value = as.numeric(Value)) %>%
      filter(!is.na(Period), !is.na(Value)) %>%
      select(Series_ID, Period, Value)
  })
}

