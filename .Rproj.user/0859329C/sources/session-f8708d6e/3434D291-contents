  )

# ── 5. Combine: use quarterly data up to Q4 2024 (Dec 2024), then monthly ─────
# Monthly index data starts Apr 2024, so the first valid monthly OTY is Apr 2025.
# Quarterly is mapped to the last month of each quarter; stopping at Dec 2024
# (Q4 2024) means the quarterly OTY series ends at Dec 2024, and the monthly
# OTY series picks up seamlessly from Apr 2025 with no overlap or gap.
quarterly_end  <- as.yearmon("Dec 2024")   # last quarterly point to include
monthly_start  <- as.yearmon("Apr 2024")   # monthly index data starts here

all_items <- bind_rows(
  quarterly_t18 %>% filter(Period <= quarterly_end),
  all_items_monthly
) %>%
  arrange(Period)

trimmed_mean <- bind_rows(
  quarterly_app %>% filter(Period <= quarterly_end),
  monthly_t6
) %>%
  arrange(Period)

# ── 6. Compute OTY % change ──────────────────────────────────────────────────
# Quarterly OTY: lag 4 (4 quarters = 1 year).
# Monthly OTY:   lag 12. Valid from Apr 2025 (12 months after monthly data begins).
# Compute each frequency separately, then recombine.

compute_oty_mixed <- function(df) {
  monthly_part <- df %>%
    filter(freq == "Month") %>%
    arrange(Period) %>%
    mutate(oty_pct_chg = (Value / lag(Value, 12)) - 1)
  
  quarterly_part <- df %>%
    filter(freq == "Quarter") %>%
    arrange(Period) %>%
    mutate(oty_pct_chg = (Value / lag(Value, 4)) - 1)
  
  bind_rows(quarterly_part, monthly_part) %>%
    arrange(Period)
}

all_items_oty    <- compute_oty_mixed(all_items)
trimmed_mean_oty <- compute_oty_mixed(trimmed_mean)

# ── 7. Combine both series for plotting ──────────────────────────────────────
