library(readxl)
library(zoo)
library(scales)
abs_path <- "C:/Users/ercun/OneDrive/Documents/EPIC ECON/Datasets/ABS/Consumer Price Index March 2026"
# ── Helper: read ABS DataX sheets ────────────────────────────────────────────
read_abs_data <- function(file_path) {
xl          <- excel_sheets(file_path)
data_sheets <- xl[str_detect(xl, "^Data\\d+$")]
map_dfr(data_sheets, function(sh) {
raw <- read_excel(file_path, sheet = sh, col_names = FALSE)
series_ids <- raw[10, -1] %>% unlist() %>% unname()
data_rows <- raw[11:nrow(raw), ]
dates <- data_rows[[1]] %>% as.numeric() %>% as.Date(origin = "1899-12-30")
data_rows[-1] %>%
set_names(series_ids) %>%
mutate(Period = dates) %>%
pivot_longer(-Period, names_to = "Series_ID", values_to = "Value") %>%
mutate(Value = as.numeric(Value)) %>%
filter(!is.na(Period), !is.na(Value)) %>%
select(Series_ID, Period, Value)
})
}
# ══════════════════════════════════════════════════════════════════════════════
# Chart 1: All Items & Trimmed Mean OTY Pct. Chg. from Jan 2016
# ══════════════════════════════════════════════════════════════════════════════
# Monthly All Items — Table 1 (Series: A130393720C)
all_items_monthly <- read_abs_data(file.path(abs_path, "640102.xlsx")) %>%
filter(Series_ID == "A130393720C") %>%
mutate(Period = as.yearmon(Period),
series_name = "All Items",
freq = "Month")
# Monthly Trimmed Mean — Table 6 (Series: A130400381L)
monthly_t6 <- read_abs_data(file.path(abs_path, "640106.xlsx")) %>%
filter(Series_ID == "A130400381L") %>%
mutate(Period = as.yearmon(Period),
series_name = "Trimmed Mean",
freq = "Month")
# Quarterly All Items — Table 18 (Series: A2325846C)
quarterly_t18 <- read_abs_data(file.path(abs_path, "6401018.xlsx")) %>%
filter(Series_ID == "A2325846C") %>%
mutate(Period = as.yearmon(as.yearqtr(Period) + 2/4),
series_name = "All Items",
freq = "Quarter")
# Quarterly Trimmed Mean — Appendix Table 1a (Series: A3604509L)
quarterly_app <- read_abs_data(file.path(abs_path, "64010Appendix1a.xlsx")) %>%
filter(Series_ID == "A3604509L") %>%
mutate(Period = as.yearmon(as.yearqtr(Period) + 2/4),
series_name = "Trimmed Mean",
freq = "Quarter")
# Combine: quarterly up to Dec 2024, then monthly onward
quarterly_end <- as.yearmon("Dec 2024")
all_items <- bind_rows(
quarterly_t18 %>% filter(Period <= quarterly_end),
all_items_monthly
) %>%
arrange(Period)
trimmed_mean <- bind_rows(
quarterly_app %>% filter(Period <= quarterly_end),
monthly_t6
) %>%
arrange(Period)
# Compute OTY % change by frequency
compute_oty_mixed <- function(df) {
monthly_part <- df %>%
filter(freq == "Month") %>%
arrange(Period) %>%
mutate(oty_pct_chg = (Value / lag(Value, 12)) - 1)
quarterly_part <- df %>%
filter(freq == "Quarter") %>%
arrange(Period) %>%
mutate(oty_pct_chg = (Value / lag(Value, 4)) - 1)
bind_rows(quarterly_part, monthly_part) %>%
arrange(Period)
}
all_items_oty    <- compute_oty_mixed(all_items)
trimmed_mean_oty <- compute_oty_mixed(trimmed_mean)
plot_data_1 <- bind_rows(
all_items_oty    %>% select(Period, series_name, oty_pct_chg),
trimmed_mean_oty %>% select(Period, series_name, oty_pct_chg)
) %>%
filter(Period >= "Jan 2016", !is.na(oty_pct_chg)) %>%
mutate(series_name = factor(series_name, levels = c("All Items", "Trimmed Mean")))
plot_data_1 %>%
ggplot(aes(x = as.Date(Period), y = oty_pct_chg, colour = series_name)) +
annotate("rect",
xmin = as.Date(as.yearmon("Jan 2016")),
xmax = as.Date(as.yearmon("Mar 2026")),
ymin = 0.02, ymax = 0.03, alpha = 0.15, fill = "grey50") +
geom_hline(yintercept = 0, linewidth = 0.6, colour = "black") +
geom_line(linewidth = 1.2) +
geom_point(size = 1.8) +
scale_colour_manual(values = c(
"All Items"    = "#0072B2",
"Trimmed Mean" = "#009E73"
)) +
labs(
x        = NULL,
y        = "(OTY Pct. Chg.)",
title    = "Australia CPI Increased 4.6% OTY in Mar. 2026",
subtitle = "Source: Australian Bureau of Statistics"
) +
scale_x_date(date_breaks = "1 years", date_labels = "%Y") +
scale_y_continuous(breaks = seq(0, 0.08, by = 0.01),
labels = label_percent(accuracy = 0.1)) +
theme_minimal(base_size = 14) +
theme(
plot.title      = element_text(size = 16, hjust = 0.5),
plot.subtitle   = element_text(size = 10, hjust = 0.5),
axis.title.y    = element_text(size = 10),
legend.position = "top",
legend.title    = element_blank(),
legend.text     = element_text(size = 12)
)
# ══════════════════════════════════════════════════════════════════════════════
# Chart 2: Contributions to Pct. Chg. — Stacked Bar Chart
# ══════════════════════════════════════════════════════════════════════════════
cont_data <- read_csv("C:/Users/ercun/OneDrive/Documents/EPIC ECON/Datasets/ABS/Consumer Price Index March 2026/abs_cont_to_pct_chg_cpi_chart_data.csv",
skip = 1,
col_names = c("Period", "All_Groups", "Food", "Alcohol_Tobacco",
"Housing", "Transport", "Recreation_Culture",
"Health_Education", "Other")) %>%
filter(!is.na(Period), !str_detect(Period, "^[a-z]|^Source")) %>%
mutate(across(All_Groups:Other, as.numeric),
Period = as.yearmon(Period, format = "%b-%y"))
cont_long <- cont_data %>%
select(-All_Groups) %>%
pivot_longer(-Period, names_to = "Group", values_to = "Contribution") %>%
mutate(Group = case_when(
Group == "Food"               ~ "Food & Non-Alcoholic Beverages",
Group == "Alcohol_Tobacco"    ~ "Alcohol & Tobacco",
Group == "Housing"            ~ "Housing",
Group == "Transport"          ~ "Transport",
Group == "Recreation_Culture" ~ "Recreation & Culture",
Group == "Health_Education"   ~ "Health & Education",
Group == "Other"              ~ "Other"
)) %>%
mutate(Group = factor(Group, levels = c("Food & Non-Alcoholic Beverages",
"Alcohol & Tobacco",
"Housing",
"Transport",
"Recreation & Culture",
"Health & Education",
"Other")))
cont_long %>%
ggplot(aes(x = as.Date(Period), y = Contribution, fill = Group)) +
geom_col() +
scale_fill_manual(values = c(
"Food & Non-Alcoholic Beverages" = "#E69F00",
"Alcohol & Tobacco"              = "#56B4E9",
"Housing"                        = "#D55E00",
"Transport"                      = "#0072B2",
"Recreation & Culture"           = "#CC79A7",
"Health & Education"             = "#009E73",
"Other"                          = "#999999"
)) +
labs(
x        = NULL,
y        = "(Percentage Points)",
title    = "Contributions to Annual CPI Percent Change",
subtitle = "Source: Australian Bureau of Statistics"
) +
scale_x_date(date_breaks = "2 months", date_labels = "%b %y") +
scale_y_continuous(labels = label_number(accuracy = 0.1)) +
theme_minimal(base_size = 14) +
theme(
plot.title      = element_text(size = 16, hjust = 0.5),
plot.subtitle   = element_text(size = 10, hjust = 0.5),
axis.title.y    = element_text(size = 10),
legend.position = "top",
legend.title    = element_blank(),
legend.text     = element_text(size = 10)
) +
guides(fill = guide_legend(nrow = 3))
